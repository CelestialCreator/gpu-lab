FROM nvidia/cuda:12.8.1-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv python3-dev \
    git git-lfs curl wget build-essential ninja-build \
    && rm -rf /var/lib/apt/lists/*

# Create venv to avoid externally-managed-environment error
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# PyTorch nightly with cu128 (includes sm_120 for RTX 5090 Blackwell)
RUN pip install --no-cache-dir --pre \
    torch torchvision torchaudio \
    --index-url https://download.pytorch.org/whl/nightly/cu128

# Core ML deps
RUN pip install --no-cache-dir \
    "transformers>=4.49.0" \
    "trl>=0.15.0" \
    accelerate \
    peft \
    datasets \
    sentencepiece \
    protobuf \
    wandb \
    tqdm \
    numpy \
    packaging \
    psutil \
    ninja

# NOTE: flash-attn skipped — compiling from source needs 20+ GB RAM.
# flash-linear-attention for Qwen3.5 DeltaNet fast kernels (triton-based, no heavy compile)
RUN pip install --no-cache-dir flash-linear-attention causal-conv1d

# Copy scripts
COPY scripts/ /opt/grpo/scripts/
WORKDIR /opt/grpo/scripts

# Workspace for data/checkpoints/outputs
RUN mkdir -p /workspace
WORKDIR /workspace

ENTRYPOINT ["python3"]
